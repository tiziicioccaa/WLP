/* Estilo para que las 4 tarjetas se vean en fila y se ajusten */
.contenedor-amigos {
    display: flex;
    justify-content: space-around;
    flex-wrap: wrap; /* Para que en móviles se pongan una debajo de otra */
    gap: 20px;
    padding: 50px;
}

.tarjeta-amigo {
    width: 200px;
    text-align: center;
    border-radius: 15px; /* Si su diseño en Canva tiene bordes redondeados */
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    transition: transform 0.3s;
}

.tarjeta-amigo:hover {
    transform: scale(1.05); /* Un toque de interactividad */
}
